# Uncomment this line to define a global platform for your project
platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  require 'fileutils'

  flutter_engine_dir = File.join(
    flutter_root,
    'bin',
    'cache',
    'artifacts',
    'engine',
    'ios',
    'Flutter.xcframework'
  )
  flutter_framework_paths = [
    File.join(flutter_engine_dir, 'ios-arm64'),
    File.join(flutter_engine_dir, 'ios-arm64_x86_64-simulator')
  ]
  flutter_header_paths = [
    File.join(flutter_engine_dir, 'ios-arm64', 'Flutter.framework', 'Headers'),
    File.join(flutter_engine_dir, 'ios-arm64_x86_64-simulator', 'Flutter.framework', 'Headers')
  ]

  # Some plugin pod headers include <Flutter/Flutter.h>. Ensure CocoaPods exposes
  # a public Flutter header/module path that those imports can resolve.
  flutter_public_headers_dir = File.join(__dir__, 'Pods', 'Headers', 'Public', 'Flutter')
  flutter_engine_headers_dir = File.join(flutter_engine_dir, 'ios-arm64', 'Flutter.framework', 'Headers')

  FileUtils.mkdir_p(flutter_public_headers_dir)
  if Dir.exist?(flutter_engine_headers_dir)
    Dir.glob(File.join(flutter_engine_headers_dir, '*.h')).each do |header|
      FileUtils.ln_sf(header, File.join(flutter_public_headers_dir, File.basename(header)))
    end
  end
  File.write(
    File.join(flutter_public_headers_dir, 'module.modulemap'),
    <<~MODULEMAP
      module Flutter {
        umbrella header "Flutter.h"

        export *
        module * { export * }
      }
    MODULEMAP
  )

  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    target.build_configurations.each do |config|
      config.build_settings['SWIFT_ENABLE_EXPLICIT_MODULES'] = 'NO'

      framework_paths = config.build_settings['FRAMEWORK_SEARCH_PATHS'] || '$(inherited)'
      header_paths = config.build_settings['HEADER_SEARCH_PATHS'] || '$(inherited)'

      flutter_framework_paths.each do |path|
        quoted = "\"#{path}\""
        framework_paths = "#{framework_paths} #{quoted}" unless framework_paths.to_s.include?(path)
      end

      flutter_header_paths.each do |path|
        quoted = "\"#{path}\""
        header_paths = "#{header_paths} #{quoted}" unless header_paths.to_s.include?(path)
      end

      config.build_settings['FRAMEWORK_SEARCH_PATHS'] = framework_paths
      config.build_settings['HEADER_SEARCH_PATHS'] = header_paths
    end
  end
end
